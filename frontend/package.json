{
    "name": "ping-web",
    "private": true,
    "type": "module",
    "imports": {
        "#styles/base": "./src/styles/base/index.css",
        "#styles/themes": "./src/styles/themes/index.css",
        "#styles/utilities": "./src/styles/utilities/index.css",
        "#styles/components": "./src/styles/components/index.css",
        "#styles/animations": "./src/styles/animations/index.css"
    },
    "scripts": {
        "dev": "cross-env NODE_OPTIONS=--import=./instrument.server.mjs vite dev",
        "build": "vite build && cp instrument.server.mjs dist/server",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:file": "vitest run",
        "test:coverage": "vitest run --coverage",
        "deploy": "npm run build && wrangler deploy",
        "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "typecheck": "tsc --noEmit 2>&1"
    },
    "dependencies": {
        "@apollo/client": "^4.1.6",
        "@apollo/client-integration-tanstack-start": "0.14.4-rc.0",
        "@cloudflare/vite-plugin": "^1.25.6",
        "@sentry/tanstackstart-react": "^10.40.0",
        "@tailwindcss/vite": "^4.2.1",
        "@tanstack/react-devtools": "^0.9.6",
        "@tanstack/react-query": "^5.90.21",
        "@tanstack/react-query-devtools": "^5.91.3",
        "@tanstack/react-router": "^1.163.3",
        "@tanstack/react-router-devtools": "^1.163.3",
        "@tanstack/react-router-ssr-query": "^1.163.3",
        "@tanstack/react-start": "^1.166.1",
        "@tanstack/react-store": "^0.9.1",
        "@tanstack/router-plugin": "^1.164.0",
        "@tanstack/store": "^0.9.1",
        "better-auth": "^1.5.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "facehash": "^0.1.0",
        "graphql": "^16.13.0",
        "lucide-react": "^0.576.0",
        "motion": "^12.34.3",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "rxjs": "^7.8.2",
        "socket.io-client": "^4.8.3",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.1",
        "tw-animate-css": "^1.4.0",
        "virtua": "^0.48.6",
        "vite-tsconfig-paths": "^6.1.1"
    },
    "devDependencies": {
        "@tanstack/devtools-event-client": "^0.4.0",
        "@tanstack/devtools-vite": "^0.5.2",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "25.3.3",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "@vitest/coverage-v8": "^4.0.18",
        "@vitest/ui": "^4.0.18",
        "babel-plugin-react-compiler": "^1.0.0",
        "cross-env": "^10.1.0",
        "jsdom": "28.0.0",
        "msw": "^2.12.10",
        "oxfmt": "^0.35.0",
        "oxlint": "^1.50.0",
        "socket.io": "^4.8.3",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vitest": "^4.0.18",
        "web-vitals": "^5.1.0",
        "wrangler": "^4.69.0"
    },
    "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
